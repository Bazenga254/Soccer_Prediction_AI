{
  "appId": "com.sparkai.prediction",
  "appName": "Spark AI",
  "webDir": "dist",
  "server": {
    "url": "https://spark-ai-prediction.com",
    "cleartext": false,
    "allowNavigation": ["spark-ai-prediction.com", "*.spark-ai-prediction.com"]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f172a",
      "showSpinner": true,
      "spinnerColor": "#6c5ce7"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0f172a"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  }
}
